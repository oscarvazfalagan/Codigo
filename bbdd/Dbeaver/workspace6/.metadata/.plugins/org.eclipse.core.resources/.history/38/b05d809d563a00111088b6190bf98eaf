DELIMITER $$

DROP FUNCTION IF EXISTS NIF_cal$$

CREATE FUNCTION NIF_cal(caracteres VARCHAR(8))
	RETURNS CHAR()
	DETERMINISTIC
BEGIN
	DECLARE resto INT;
	DECLARE letra CHAR(1);
	DECLARE letras CHAR(23);
	SET letras = 'TRWAGMYFPDXBNJZSQVHLCKE';
	IF SUBSTRING(caracteres,1,1)='X'THEN SET resto = SUBSTRING(caracteres,2,7)%23;
	ELSEIF(SUBSTRING(caracteres,1,1)='Y') THEN SET resto = CONCAT(10000000+SUBSTRING(caracteres,2,7))%23;
	ELSEIF(SUBSTRING(caracteres,1,1)='Z') THEN SET resto = CONCAT(20000000+SUBSTRING(caracteres,2,7))%23;
	END IF;
	RETURN SUBSTRING(letras, resto+1, 1);
END$$
DElIMITER ;


