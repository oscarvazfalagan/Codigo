-- q7
SELECT v.ven_data,c.clt_apelidos,c.clt_apelidos,e.emp_apelidos ,e.emp_nome,(dv.dev_cantidade * dv.dev_prezo_unitario * ((100-dv.dev_desconto)/100)) as importe
FROM tendas t 
JOIN vendas v ON (t.tda_id = v.ven_tenda )
JOIN empregados e ON (e.emp_id = t.tda_xerente )
JOIN detalle_vendas dv ON (v.ven_id = dv.dev_venda)
JOIN clientes c ON(c.clt_id = v.ven_cliente )
WHERE (dv.dev_cantidade * dv.dev_prezo_unitario * ((100-dv.dev_desconto)/100)) < 15577
ORDER BY importe desc,v.ven_data 





