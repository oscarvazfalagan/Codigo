SELECT d.doc_name,d.`path`,d.upload_date ,u.nombre,c.center_name as centro_usuario
FROM documents d 
JOIN projects p ON (p.id_project = d.id_project )
JOIN aux_document_type dt ON(dt.id_document_type = d.id_document_type )
JOIN usuarios u ON (d.id_user = u.id_usuario )
