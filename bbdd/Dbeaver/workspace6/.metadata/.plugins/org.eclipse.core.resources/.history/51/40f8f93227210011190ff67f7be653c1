SELECT *
FROM projects p 
JOIN rel_user_project_input_hours pi ON(p.id_project = pi.id_project ) 
JOIN usuarios u ON(u.id_usuario = pi.id_project )
JOIN centers c ON(c.id_center = u.id_center)
