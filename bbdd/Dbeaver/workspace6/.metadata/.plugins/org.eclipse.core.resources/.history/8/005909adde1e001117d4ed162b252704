-- q1
SELECT u.nombre,g.grupo,c.center_name 
FROM usuarios u 
JOIN grupos g ON (u.id_grupo = g.id_grupo )
JOIN centers c ON (u.id_center = c.id_center )
WHERE u.theme LIKE('default')
ORDER BY nombre;


-- q2
SELECT u.last_date ,u.nombre,c.center_name
FROM usuarios u 
JOIN grupos g ON (g.id_grupo = u.id_grupo)
JOIN centers c ON (u.id_center = c.id_center)
WHERE (YEAR(u.last_date) LIKE('2019') AND month(u.last_date) LIKE('10'))AND(u.id_grupo LIKE('2'))
ORDER BY u.last_date,u.nombre;


