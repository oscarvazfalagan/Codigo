-- q6
SELECT DISTINCT e.empExtension ,COUNT (e.empExtension) AS empregadosUsando
FROM empregado e 
GROUP BY e.empExtension;

-- q7
SELECT COUNT(e.empFillos) AS N_personas,e.empFillos as numero_filloas
FROM empregado e 
GROUP BY e.empFillos
ORDER BY N_personas ,numero_filloas ;

-- q8
SELECT d.depNome ,e.empFillos as numero_filloas
FROM empregado e 
join departamento d on (d.depNumero = e.empDepartamento )
ORDER BY numero_filloas DESC ,d.depNome;

-- q9
SELECT c.cenNome,COUNT(d.depCentro)  
FROM departamento d 
JOIN centro c ON (c.cenNumero = d.depCentro )
GROUP BY d.depCentro

-- q10
SELECT d.depNome ,d.depNumero ,MAX(e.empSalario) AS salarioMaxForDepartament,MIN(e.empSalario) as salarioMinForDepartament ,
(MAX(e.empSalario)-MIN(e.empSalario)) AS DifSalari
FROM departamento d 
JOIN empregado e on (e.empDepartamento = d.depNumero  )
GROUP BY e.empDepartamento ;

-- q11
SELECT d.depPresuposto, (d.depPresuposto-(SUM(e.empSalario+IFNULL(e.empComision,0))	)) AS presupostoRestante
FROM departamento d 
JOIN empregado e on (e.empDepartamento = d.depNumero )
GROUP BY e.empDepartamento 

