-- q1
SELECT p.apellidos,p.nombre
FROM persona p 
WHERE p.apellidos LIKE('%Estévez')
ORDER BY p.apellidos,p.nombre;

-- q2
SELECT p.apellidos,p.nombre
FROM persona p 
WHERE p.apellidos LIKE('Fernández%')

-- q3
SELECT p.apellidos,p.nombre
FROM persona p 
WHERE (p.id_persona != (SELECT p2.madre FROM persona p2) OR p.id_persona != (SELECT p2.padre FROM persona p2)) AND p.apellidos LIKE('%Estévez')
ORDER BY p.apellidos,p.nombre;