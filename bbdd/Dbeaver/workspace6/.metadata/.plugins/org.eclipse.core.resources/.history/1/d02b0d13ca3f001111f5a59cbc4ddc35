DROP TRIGGER IF EXISTS centroAU;
DROP TRIGGER IF EXISTS centroAI;
DROP TRIGGER IF EXISTS centroAD;
DROP TRIGGER IF EXISTS departamentoAU;
DROP TRIGGER IF EXISTS departamentoAI;
DROP TRIGGER IF EXISTS departamentoAD;
DROP TRIGGER IF EXISTS empregadoAU;
DROP TRIGGER IF EXISTS empregadoAI;
DROP TRIGGER IF EXISTS empregadoAD;

DROP PROCEDURE IF EXISTS llenarRexistro;

DELIMITER //
CREATE PROCEDURE llenarRexistro(taboaR varchar(50),operacionR varchar(6))
BEGIN
	INSERT INTO rexistroOperacions(usuario,dataHora,taboa,operacion)
	VALUES (
		CURRENT_USER(),NOW(),taboaR,operacionR);
END //



CREATE TRIGGER centroAI
AFTER INSERT ON centro
FOR EACH ROW 
BEGIN 
	CALL llenarRexistro('centro','insert');
END //

CREATE TRIGGER centroAU
AFTER UPDATE ON centro
FOR EACH ROW 
BEGIN 
	CALL llenarRexistro('centro','update');
END //

CREATE TRIGGER centroAD
AFTER DELETE ON centro
FOR EACH ROW 
BEGIN 
	CALL llenarRexistro('centro','delete');
END //

CREATE TRIGGER departamentoAD
AFTER DELETE ON departamento
FOR EACH ROW 
