-- q1
SELECT a.art_codigo, ROUND(AVG(a.art_pv),2) as media,a.art_color
FROM artigos a 
WHERE a.art_color IS NOT NULL
GROUP BY a.art_color
order by a.art_codigo ,media ;

-- q2
SELECT a.art_codigo, ROUND(AVG(a.art_pv),2) as media,a.art_color
FROM artigos a 
WHERE a.art_pv >= 50 AND a.art_color IS NOT NULL
GROUP BY a.art_color
order by a.art_codigo ,media ;

-- q3
SELECT c.clt_poboacion, COUNT(c.clt_id) AS Habitantes
FROM clientes c 
GROUP BY c.clt_poboacion
ORDER BY Habitantes DESC ;

-- q4
SELECT a.art_codigo,SUM(dv.dev_cantidade*dv.dev_prezo_unitario)AS prezo_sen_desconto
FROM artigos a 
JOIN detalle_vendas dv ON ( dv.dev_artigo  = a.art_codigo )
JOIN vendas v ON (dv.dev_venda  = v.ven_id )
WHERE v.ven_data >='2015-01-01'AND v.ven_data  < '2015-05-26'
GROUp BY a.art_codigo
ORDER BY a.art_codigo,prezo_sen_desconto 
-- q5
SELECT t.tda_id, COUNT(v.ven_id) AS NumeroVendas,COUNT(distinct(dv.dev_artigo)) AS NumeroArtigos,SUM(dv.dev_cantidade)AS unidadesVendidas,ROUND(AVG(dv.dev_prezo_unitario),2)AS precio
FROM vendas v 
JOIN tendas t  ON (t.tda_id = v.ven_tenda )
JOIN detalle_vendas dv ON (dv.dev_venda  = v.ven_id )
WHERE YEAR(v.ven_data) = 2015
GROUP BY t.tda_id;
