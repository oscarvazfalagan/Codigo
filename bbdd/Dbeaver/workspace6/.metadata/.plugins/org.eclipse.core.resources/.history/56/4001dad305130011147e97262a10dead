-- q6
SELECT DISTINCT e.empExtension ,COUNT (e.empExtension) AS empregadosUsando
FROM empregado e 
GROUP BY e.empExtension;

-- q7
SELECT COUNT(e.empFillos) AS N_personas,e.empFillos as numero_filloas
FROM empregado e 
GROUP BY e.empFillos 

-- q8
SELECT d.depNome ,e.empFillos as numero_filloas
FROM empregado e 
join departamento d on (d.depNumero = e.empDepartamento )
ORDER BY e.empFillos