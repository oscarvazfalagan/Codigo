CREATE TABLE IF NOT EXISTS traballadores.rexistroOperacions
(
	idTraspaso integer UNSIGNED NOT NULL AUTO_INCREMENT,
	num_licencia_xogador smallint(6) NOT NULL ,
	# usuario que fai oa modificación
	codigo_equipo_orixe char(4),
	# data e hora na que se fai a modificación
	codigo_equipo_destino char(4),
	# táboa na que se fai a modificación
	data_traspaso date NOT NULL,
	# operación de modificación: INSERT, UPDATE, DELETE
	PRIMARY KEY (idOperacion)
)ENGINE = MYISAM;