DROP PROCEDURE IF EXISTS calcularPago;
DROP TRIGGER IF EXISTS af_xogador;
DROP TRIGGER IF EXISTS ad_xogador;

DELIMITER //
CREATE PROCEDURE calcularPago(in empSalario decimal(6,2),empComision decimal(6,2),out total int UNSIGNED)
BEGIN
	IF empComision = NULL THEN
		SET	empComision = 0;
	END IF
	SET total = empComision + empSalario;
	
	END //

CREATE TRIGGER af_xogador
AFTER INSERT ON	xogador
FOR EACH ROW 
BEGIN 
	CALL calcularPago(new.numero_licencia,NULL,new.codigo_equipo);
END //


CREATE TRIGGER ad_xogador
AFTER UPDATE  ON xogador
FOR EACH ROW 
BEGIN 
	CALL llenarRexistro(new.numero_licencia,old.codigo_equipo,new.codigo_equipo);
END //

DELIMITER ;

