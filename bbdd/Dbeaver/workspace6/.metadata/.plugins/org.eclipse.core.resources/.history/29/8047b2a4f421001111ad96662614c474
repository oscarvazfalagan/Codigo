-- q1
SELECT x.nome,x.posicion,n.nome as nacionalidad_nome,e.nome_equipo,x.data_nacemento
FROM xogador x
LEFT JOIN equipo e  ON (x.codigo_equipo = e.codigo)
LEFT JOIN nacionalidade n ON (x.nacionalidade = n.codigo )
WHERE TIMESTAMPDIFF(YEAR,CURDATE(),x.data_nacemento)<=38
ORDER BY x.data_nacemento DESC,x.nome,x.posicion;

-- q2
SELECT x.*
FROM xogador x 
LEFT JOIN equipo e  ON (x.codigo_equipo = e.codigo)
LEFT JOIN nacionalidade n ON (x.nacionalidade = n.codigo)
WHERE (TIMESTAMPDIFF(YEAR,CURDATE(),x.data_nacemento) >= 37 and TIMESTAMPDIFF(YEAR,CURDATE(),x.data_nacemento) <=47) 
ORDER BY x.data_nacemento DESC,x.nome ,x.posicion 
