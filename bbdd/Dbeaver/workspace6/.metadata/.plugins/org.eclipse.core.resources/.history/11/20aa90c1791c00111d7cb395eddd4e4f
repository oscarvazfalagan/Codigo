-- q1
CREATE VIEW artigos_provedor
AS(
	SELECT a.art_codigo,a.art_nome,p.prv_nome
	FROM artigos a 
	left join provedores p ON (a.art_provedor = p.prv_id )
);
-- q2
CREATE VIEW artigos_venta
AS(
	SELECT a.art_codigo,dv.dev_cantidade
	FROM  detalle_vendas dv 
	join artigos a ON (dv.dev_artigo = a.art_codigo )
);
-- q3
CREATE VIEW tenda30_detalles
AS(
	SELECT  dv.*
	FROM  detalle_vendas dv 
	join vendas v ON (v.ven_id = dv.dev_venda )
	join tendas t ON (v.ven_tenda = t.tda_id )
	WHERE t.tda_id = 30
);

