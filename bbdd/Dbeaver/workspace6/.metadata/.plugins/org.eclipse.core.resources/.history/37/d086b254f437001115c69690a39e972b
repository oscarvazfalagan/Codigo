DELIMITER $$
DROP PROCEDURE IF EXISTS pruebaTenda$$
CREATE PROCEDURE pruebaTenda()
BEGIN
	INSERT INTO vendas (ven_tenda,ven_empregado,ven_cliente,ven_data)
	VALUES (
	(SELECT v.ven_tenda  FROM vendas v ORDER BY rand() limit 1),
	(SELECT v.ven_empregado  FROM vendas v ORDER BY rand() limit 1),
	(SELECT v.ven_cliente FROM vendas v ORDER BY rand() limit 1),
	(CURDATE()));	
END
$$
DElIMITER ;
 
