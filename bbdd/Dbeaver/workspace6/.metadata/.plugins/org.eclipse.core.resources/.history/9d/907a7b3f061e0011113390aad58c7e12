-- q1
SELECT p.apellidos,p.nombre
FROM persona p 
WHERE p.apellidos LIKE('%Estévez')
ORDER BY p.apellidos,p.nombre;

-- q2
SELECT p.apellidos,p.nombre
FROM persona p 
WHERE p.apellidos LIKE('Fernández%')

-- q3
SELECT p.apellidos, p.nombre
FROM persona p
WHERE p.apellidos LIKE ('%Estévez%')AND (p.id_persona NOT IN (SELECT DISTINCT p2.padre FROM persona p2 WHERE p2.padre IS NOT NULL)) AND (p.id_persona NOT IN (SELECT DISTINCT p3.madre FROM persona p3 WHERE p3.madre IS NOT NULL))
ORDER BY p.apellidos, p.nombre;

-- q4
SELECT p.apellidos, p.nombre
FROM persona p
JOIN persona pro ON (pro.id_persona =p.padre OR pro.id_persona =p.madre )
WHERE pro.apellidos like('%Costas%')
ORDER BY p.apellidos, p.nombre;

-- q5
SELECT p.apellidos,p.nombre,abuel.apellidos,abuel.nombre
FROM persona p 
JOIN persona pro ON (pro.id_persona =p.padre OR pro.id_persona =p.madre )
JOIN persona abuel ON (pro.padre  = abuel.id_persona OR pro.madre =abuel.id_persona)
WHERE abuel.apellidos LIKE('%Darriba%')
ORDER By p.apellidos,p.nombre;

-- q6
SELECT p.apellidos, p.nombre,count(h.id_persona) AS num_hijos
FROM persona p
LEFT JOIN persona h ON (h.padre = p.id_persona OR h.madre = p.id_persona )
GROUP BY p.id_persona
ORDER BY num_hijos DESC,p.apellidos,p.nombre;


-- q7
SELECT p.apellidos ,p.nombre,COUNT(h.id_persona)AS num_hijos,(
	SELECT  AVG(tabla.num_hijos)
		FROM (
		SELECT count(h.id_persona) AS num_hijos
		FROM persona p 
		LEFT JOIN persona h ON (h.padre = p.id_persona OR h.madre = p.id_persona )
		GROUP BY p.id_persona
		ORDER BY num_hijos DESC,p.apellidos,p.nombre
		) as tabla
	)AS  media_hijos
FROM persona p 
LEFT JOIN persona h ON (h.padre = p.id_persona OR h.madre = p.id_persona )
GROUP BY p.id_persona
HAVING num_hijos > media_hijos 
ORDER BY num_hijos DESC,p.apellidos,p.nombre;


-- q8


SELECT AVG(personasMayormediaHijos.media_hijos)
FROM (SELECT COUNT(h.id_persona)AS num_hijos,(
			SELECT  AVG(tabla.num_hijos)
				FROM (
				SELECT count(h.id_persona) AS num_hijos
				FROM persona p 
				LEFT JOIN persona h ON (h.padre = p.id_persona OR h.madre = p.id_persona )
				GROUP BY p.id_persona
				ORDER BY num_hijos DESC,p.apellidos,p.nombre
				) as tabla
			)AS  media_hijos
	FROM persona p 
	LEFT JOIN persona h ON (h.padre = p.id_persona OR h.madre = p.id_persona )
	GROUP BY p.id_persona
	HAVING num_hijos > media_hijos)as personasMayormediaHijos

