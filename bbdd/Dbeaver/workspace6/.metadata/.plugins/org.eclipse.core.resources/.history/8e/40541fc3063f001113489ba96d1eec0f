DROP PROCEDURE IF EXISTS llenarRexistro;

DELIMITER //
CREATE PROCEDURE llenarRexistro(taboaR char(50),operacionR char(6))
BEGIN
	UPDATE rexistroOperaciones
	SET
		usuario = CURRENT_USER(),
		dataHora = NOW(),
		taboa = taboaR,
		operacion = operacionR;
END //

CREATE TRIGGER centroAI
AFTER INSERT ON centro
FOR EACH ROW 
BEGIN 
	UPDATE rexistroOperaciones
	CALL llenarRexistro('centro','insert');
END //





