-- q8
SELECT e.empNome,
(SELECT d.depNome  FROM departamento d WHERE e.empDepartamento = d.depEmpregados ) AS nome_departamento 
FROM empregado e 
WHERE e.empDepartamento IN(
SELECT d.depEmpregados FROM departamento d  WHERE d.depCentro LIKE 'SEDE CENTRAL' )
ORDER BY e.empNome,nome_departamento ;

