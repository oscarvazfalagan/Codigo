-- q1
SELECT a.art_codigo  ,a.art_peso
FROM artigos a 
WHERE a.art_peso > (SELECT a2.art_peso FROM artigos a2 WHERE a2.art_codigo LIKE '077WN45')


-- q2
SELECT a.art_codigo,a.art_nome,a.art_peso,a.art_color 
FROM artigos a 
WHERE a.art_color = (SELECT a2.art_color  FROM artigos a2 WHERE a2.art_codigo  LIKE '242C283' )
AND a.art_peso >= (SELECT AVG(a.art_peso) AS media FROM artigos a2) ;

-- q3 
SELECT t.tda_id,(SELECT e.emp_nome FROM empregados e WHERE e.emp_id = t.tda_xerente ) AS nombre_xerente
FROM tendas t 
WHERE t.tda_id in 
	(
	SELECT v.ven_tenda  
	FROM vendas v  
	WHERE v.ven_id  in(
		SELECT dv.dev_venda
		FROM detalle_vendas dv 
		WHERE dv.dev_artigo in(
			SELECT a.art_codigo
			FROM artigos a 
			WHERE a.art_codigo LIKE'077WN45'
			)
		)
	);
 
-- q4
SELECT a.art_nome
FROM artigos a 
WHERE a.art_pv >ANY(SELECT a2.art_color FROM artigos a2  WHERE a2.art_color LIKE 'NEGRO');

-- q5
SELECT a.art_codigo,a.art_nome,a.art_provedor
FROM artigos a 
WHERE a.art_provedor = (SELECT p.prv_id FROM provedores p WHERE p.prv_nome LIKE'SEAGATE')

-- q6
SELECT a.art_codigo,a.art_nome,a.art_pv,(SELECT p.prv_nome  FROM provedores p WHERE p.prv_id = a.art_provedor )as nombre
FROM artigos a 
WHERE a.art_pv = (SELECT MAX(a2.art_pv) FROM artigos a2 )



